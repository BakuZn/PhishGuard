{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0",
  "description": "Phishing detection extension",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": ["https://mail.google.com/*"],

  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
