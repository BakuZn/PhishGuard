{
  "manifest_version": 3,
  "name": "PhishGuard Elite",
  "version": "2.0",
  "description": "AI Threat Intelligence & Phishing Detection Platform",

  "permissions": ["activeTab", "scripting", "storage"],

  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:8000/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishGuard Elite Dashboard"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}
